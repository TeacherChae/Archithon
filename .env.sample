# ── HuggingFace ───────────────────────────────────────────────────────────────
# HuggingFace Access Token (https://huggingface.co/settings/tokens)
# facebook/sam3 등 gated 모델 다운로드 시 필요
HUGGING_FACE_HUB_TOKEN=

# ── Device ────────────────────────────────────────────────────────────────────
# 사용할 연산 장치: "cuda" (GPU) 또는 "cpu"
DEVICE=cuda

# ── MoGe-2 (깊이 추정 모델) ───────────────────────────────────────────────────
# HuggingFace 모델 ID
MOGE_MODEL=Ruicheng/moge-2-vitl-normal
# 추론 해상도 레벨 (0~9, 높을수록 고해상도)
MOGE_RESOLUTION_LEVEL=9
# FP16 추론 활성화 여부 (VRAM 절약, 속도 향상) - "true" / "false"
MOGE_FP16=false

# ── SAM3 (세그멘테이션 모델) ──────────────────────────────────────────────────
# 인스턴스 감지 최소 신뢰도 (0.0 ~ 1.0)
SAM_CONFIDENCE_THRESHOLD=0.3
# 세그멘테이션할 레이블 목록 (쉼표 구분)
SAM_LABELS=rooftop,building exterior wall facade,window
# 여러 인스턴스를 하나로 합칠 레이블 (쉼표 구분, 빈 값이면 비활성화)
SAM_MERGE_LABELS=window

# ── Mesh 재구성 ───────────────────────────────────────────────────────────────
# 재구성 방법:
#   gpu_poisson — CUDA 전처리 + CPU Screened Poisson (기본값, 권장)
#                 MoGe 법선 재사용으로 estimate_normals 생략 → 빠름
#   voxel_mc    — GPU 복셀화 + CPU Marching Cubes
#   poisson     — 순수 CPU Poisson (느림)
#   bpa / alpha — CPU Ball Pivoting / Alpha Shape
MESH_METHOD=gpu_poisson
# Poisson 옥트리 깊이 (높을수록 세밀, 느림 / gpu_poisson·poisson 공용)
MESH_DEPTH=8
# 처리할 최대 포인트 수 (메모리 제한 시 줄일 것)
MESH_MAX_POINTS=150000
# Voxel 그리드 해상도 (MESH_METHOD=voxel_mc 전용)
MESH_VOXEL_RESOLUTION=128
# 출력 메시 포맷 (쉼표 구분): "glb", "ply", "obj" 등
MESH_OUTPUT_FORMATS=glb,ply,3dm

# ── Pipeline 출력 ─────────────────────────────────────────────────────────────
# 결과 파일 저장 디렉토리
OUTPUT_DIR=output
# 중간 결과물 저장 여부 (depth, seg, cloud 시각화 등) - "true" / "false"
SAVE_INTERMEDIATES=true
